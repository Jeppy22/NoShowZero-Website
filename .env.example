# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Gmail SMTP (use App Password, not your real password)
# Setup: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jeffrey@noshowzero.tech
SMTP_PASS=your-16-character-app-password

# Where contact form submissions get sent
CONTACT_EMAIL=jeffrey@noshowzero.tech
